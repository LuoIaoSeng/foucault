// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  STUDENT  @map("student")
  EDUCATOR @map("educator")
  EMPLOYEE @map("employee")
  ADMIN    @map("admin")
}

model User {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  password   String
  firstname  String?
  lastname   String
  nickname   String?
  avatorPath String?
  gender     String
  birthday   DateTime
  role       Role     @default(STUDENT)
  facultyId  Int?
  createAt   DateTime @default(now())
  updateAt   DateTime @updatedAt

  faculty       Faculty?       @relation(fields: [facultyId], references: [id])
  sendMessages  SendMessage[]
  inboxMessages InboxMessage[]
  courses              Course[]               @relation("EducatorCourses")
  taCourses            Course[]               @relation("TaCourses")
  enrollments          Enrollment[]
  assignmentSubmissions AssignmentSubmission[]
}

model SendMessage {
  id       Int      @id @default(autoincrement())
  userId   Int
  content  Json
  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  inboxMessages InboxMessage[]
}

model InboxMessage {
  id         Int @id @default(autoincrement())
  messageId  Int
  receiverId Int

  receiveUser User        @relation(fields: [receiverId], references: [id])
  message     SendMessage @relation(fields: [messageId], references: [id])
}

model Faculty {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  createAt    DateTime @default(now())

  users   User[]
  courses Course[]
}

model Course {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  content     Json?
  semester    String
  educatorId  Int
  facultyId   Int?
  createAt    DateTime @default(now())
  updateAt    DateTime @updatedAt

  educator    User         @relation("EducatorCourses", fields: [educatorId], references: [id])
  faculty     Faculty?     @relation(fields: [facultyId], references: [id])
  tas                   User[]                   @relation("TaCourses")
  enrollments           Enrollment[]
  assignmentSubmissions AssignmentSubmission[]
}

model Enrollment {
  id         Int      @id @default(autoincrement())
  userId     Int
  courseId   Int
  enrolledAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model AssignmentSubmission {
  id           Int      @id @default(autoincrement())
  assignmentId String
  courseId     Int
  userId       Int
  fileUrl      String
  fileName     String
  submittedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([assignmentId, userId])
}
