// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  STUDENT @map("student")
  EDUCATOR @map("educator")
  EMPLOYEE @map("employee")
  ADMIN @map("admin")
}

model User {
  id Int @id @default(autoincrement())
  username String @unique
  password String
  first_name String?
  last_name String
  nickname String?
  avator_path String?
  gender String
  birthday DateTime
  role Role @default(STUDENT)
  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  SendMessages InboxMessage[] @relation("FromUser")
  ReceiveMessages InboxMessage[] @relation("ToUser")
}

model InboxMessage {
  id Int @id @default(autoincrement())
  fromUserId Int
  toUserId Int
  content Json
  createAt DateTime @default(now())
  updateAt DateTime @updatedAt
  
  FromUser User @relation(name: "FromUser", fields: [fromUserId], references: [id])
  ToUser User @relation(name: "ToUser", fields: [toUserId], references: [id])
}
